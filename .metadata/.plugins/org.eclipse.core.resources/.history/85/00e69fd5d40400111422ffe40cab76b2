package MustKnow;
import java.util.*;
import java.util.stream.*;

public class ArrayAllMethods {
    public static void main(String[] args) {

        int[] a = {5, 3, 9, 1};
        int[] b = {5, 3, 9, 1};

        // sort
        Arrays.sort(a);
        System.out.println(Arrays.sort(a));
        System.out.println("Sort: " + Arrays.toString(a));

        // parallelSort
        int[] p = {8, 2, 6, 4};
        Arrays.parallelSort(p);
        System.out.println("ParallelSort: " + Arrays.toString(p));

        // binarySearch
        System.out.println("BinarySearch 5: " + Arrays.binarySearch(a, 5));

        // equals
        System.out.println("Equals: " + Arrays.equals(a, b));

        // deepEquals
        int[][] m1 = {{1, 2}, {3, 4}};
        int[][] m2 = {{1, 2}, {3, 4}};
        System.out.println("DeepEquals: " + Arrays.deepEquals(m1, m2));

        // copyOf
        int[] c = Arrays.copyOf(a, 6);
        System.out.println("CopyOf: " + Arrays.toString(c));

        // copyOfRange
        int[] d = Arrays.copyOfRange(a, 1, 3);
        System.out.println("CopyOfRange: " + Arrays.toString(d));

        // fill
        Arrays.fill(d, 7);
        System.out.println("Fill: " + Arrays.toString(d));

        // hashCode
        System.out.println("HashCode: " + Arrays.hashCode(a));

        // stream
        int sum = Arrays.stream(a).sum();
        System.out.println("Stream sum: " + sum);

        // mismatch
        System.out.println("Mismatch index: " + Arrays.mismatch(a, b));

        // asList
        Integer[] x = {10, 20, 30};
        List<Integer> list = Arrays.asList(x);
        System.out.println("AsList: " + list);

        // deepToString
        System.out.println("DeepToString: " + Arrays.deepToString(m1));
    }
}
